<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mcs.ofx2csv.controller.MainController"
      alignment="CENTER">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <!-- Zone 1: Drop Zone Card -->
    <StackPane fx:id="dropZone" styleClass="drop-zone" onMouseClicked="#pickFiles"
               minWidth="680" prefHeight="100" VBox.vgrow="NEVER">
        <VBox alignment="CENTER" spacing="6">
            <Label fx:id="dropZoneIcon" styleClass="text-muted" text="&#128196;" style="-fx-font-size: 28px;"/>
            <Label fx:id="dropZoneLabel" styleClass="text-muted"
                   text="Arraste seus arquivos OFX aqui ou clique para selecionar"/>
            <!-- File chips container (initially hidden) -->
            <HBox fx:id="fileListContainer" spacing="6" style="-fx-padding: 8px 0 0 0;" managed="false" visible="false"/>
            <Label fx:id="fileCountLabel" styleClass="text-muted-small" managed="false" visible="false"/>
        </VBox>
    </StackPane>

    <!-- Zone 2: Destination Folder -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label styleClass="section-label" text="Destino:"/>
        <TextField fx:id="dirField" styleClass="dir-field" editable="false"
                   HBox.hgrow="ALWAYS" promptText="Selecione a pasta de destino..."/>
        <Button styleClass="button-secondary" text="&#128193;" onAction="#pickDirectory">
            <tooltip><Tooltip text="Selecionar pasta (Ctrl+S)"/></tooltip>
        </Button>
    </HBox>

    <!-- Zone 3: Preview Table Card -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="0">
        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 0 0 8px 0;">
            <Label styleClass="section-label" text="Pré-visualização"/>
            <ChoiceBox fx:id="fileSelector" visible="false" managed="false" minWidth="150"/>
            <Label fx:id="transactionCountLabel" styleClass="text-muted-small"/>
        </HBox>
        <TableView fx:id="previewTable" VBox.vgrow="ALWAYS" maxHeight="180">
            <placeholder>
                <Label text="Nenhum arquivo selecionado" styleClass="text-muted"/>
            </placeholder>
            <columns>
                <TableColumn fx:id="colDate" text="Data Balancete" prefWidth="110" resizable="false"/>
                <TableColumn fx:id="colHistorico" text="Historico" prefWidth="220"/>
                <TableColumn fx:id="colDebito" text="Débito" prefWidth="90" resizable="false"/>
                <TableColumn fx:id="colCredito" text="Crédito" prefWidth="90" resizable="false"/>
                <TableColumn fx:id="colSoma" text="Soma" prefWidth="90" resizable="false"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

    <!-- Zone 4: Convert Button + Feedback Bar -->
    <VBox spacing="0" styleClass="card" style="-fx-padding: 0;">
        <VBox alignment="CENTER" spacing="12" style="-fx-padding: 16px;">
            <Button fx:id="convertButton" styleClass="button-primary" text="Converter"
                    onAction="#convert" defaultButton="true">
                <tooltip><Tooltip text="Converter arquivos (Enter)"/></tooltip>
            </Button>
            <Hyperlink text="github.com/edurbs" style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF; -fx-border-color: transparent;"
                       onAction="#openGitHub"/>
        </VBox>
        <!-- Feedback bar (initially hidden) -->
        <VBox fx:id="feedbackBar" styleClass="feedback-bar" managed="false" visible="false">
            <HBox alignment="CENTER_LEFT" spacing="4">
                <Label fx:id="feedbackIcon" styleClass="feedback-icon"/>
                <Label fx:id="feedbackMessage" styleClass="feedback-text" HBox.hgrow="ALWAYS"/>
                <Hyperlink fx:id="feedbackAction" styleClass="feedback-action"
                           text="Abrir pasta" onAction="#openOutputFolder"
                           managed="false" visible="false"/>
                <Button fx:id="feedbackDismiss" styleClass="feedback-dismiss"
                        text="&#10005;" onAction="#hideFeedback"/>
            </HBox>
            <TextArea fx:id="feedbackDetails" styleClass="feedback-details"
                      editable="false" wrapText="true"
                      managed="false" visible="false" maxHeight="80"/>
        </VBox>
    </VBox>
</VBox>
